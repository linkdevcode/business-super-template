VITE_API_URL=http://localhost:5000
# URL của Backend API khi chạy local qua Docker (map 5000 -> 8080 trong container).

VITE_API_BASE_URL=http://localhost:5210
# URL Backend API khi chạy trực tiếp bằng `dotnet run` (không qua Docker), giữ lại để tương thích với code hiện tại.

VITE_APP_URL=http://localhost:5173
# URL của frontend SPA khi chạy `npm run dev`.

